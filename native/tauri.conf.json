{
  "productName": "Tahoma2D MCP",
  "version": "0.1.0",
  "identifier": "ai.fleet.tahoma2d-mcp",
  "build": {
    "frontendDist": "../webapp/dist",
    "devUrl": "http://localhost:11012",
    "beforeDevCommand": "npm --prefix ../webapp run dev"
  },
  "app": {
    "windows": [{
      "title": "Tahoma2D MCP",
      "width": 1100,
      "height": 750,
      "minWidth": 700,
      "minHeight": 500
    }],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
    "externalBin": ["binaries/{name}-backend"]
  },
  "plugins": {
    "shell": { "open": true },
    "fs": { "requireLiteralLeadingDot": false },
    "process": { "all": true }
  }
}
